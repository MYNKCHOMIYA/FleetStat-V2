# .env.local — Use this for LOCAL development (uvicorn app.main:app --reload)
# Copy this to .env when developing locally, or run: ENV_FILE=.env.local uvicorn ...
# This connects to the Docker Postgres from your host machine (port 5433)

SECRET_
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DB_HOST=localhost
DB_PORT=5433
DB_NAME=fleetstat
DB_USER=postgres
DB_PASSWORD=admin
